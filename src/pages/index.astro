---
export const prerender = true;
import FundingLayout from '../layouts/FundingLayout.astro';

const title = 'LeadSniper Marketplace | Canadian Business Funding, Matched to You';
const description = 'Compare Canadian business funding — lines of credit, equipment financing, commercial mortgages, acquisition financing, working capital, and CSBFP government-backed loans. One 3-minute assessment, human-reviewed matches.';
const canonicalPath = '/';
const keyword = 'business funding canada';

const fundingOptions = [
  { icon: '🔄', name: 'Business Line of Credit', desc: 'Revolving credit up to $3M. Pay interest only on what you use.', url: '/business-line-of-credit-canada', cta: 'Compare rates' },
  { icon: '🏗️', name: 'Equipment Financing', desc: 'Finance new or used equipment. Up to 100% financing. Bad credit OK.', url: '/equipment-financing-canada', cta: 'Compare lenders' },
  { icon: '🏢', name: 'Commercial Mortgages', desc: 'CMHC-insured from 4.25%. A-lender, B-lender, and private options.', url: '/commercial-mortgage-rates-canada', cta: 'View rate tables' },
  { icon: '🤝', name: 'Business Acquisition', desc: 'Senior debt, CSBFP, seller financing, mezzanine — layered deals.', url: '/business-acquisition-financing', cta: 'See deal structures' },
  { icon: '💵', name: 'Working Capital Loans', desc: 'From $5K to $800K. Term loans and lines of credit. Fast approval.', url: '/working-capital-loans-canada', cta: 'Compare lenders' },
  { icon: '🏛️', name: 'CSBFP (Government)', desc: 'Government-backed loans up to $1M. Lines of credit up to $150K.', url: '/canada-small-business-financing-program', cta: 'Check eligibility' },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'LeadSniper Marketplace',
    url: 'https://leadsniperai.ca',
    description: 'Canadian business funding assessment platform connecting business owners with verified financial professionals.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'LeadSniper Marketplace',
    url: 'https://leadsniperai.ca',
  },
];
---

<FundingLayout title={title} description={description} canonicalPath={canonicalPath} jsonLd={jsonLd} keyword={keyword}>

<!-- Hero -->
<section class="hero">
  <div class="container">
    <h1>Canadian Business Funding, <span class="gold">Matched to You</span></h1>
    <p class="sub">Compare lines of credit, equipment financing, commercial mortgages, acquisition financing, working capital, and government-backed programs. One guided assessment. Human review before any match.</p>
    <div class="hero-cta">
      <a href="#assessment" class="btn btn-primary btn-lg">Check My Funding Options</a>
      <a href="/business-funding-canada" class="btn btn-secondary btn-lg" style="color: #fff; border-color: rgba(255,255,255,0.4);">Browse All Options</a>
    </div>
    <div class="hero-reassurance">
      <span><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg> Takes 3–5 minutes</span>
      <span><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg> No obligation</span>
      <span><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg> No impact on credit</span>
      <span><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg> Human review before matching</span>
    </div>
  </div>
</section>

<!-- Funding options -->
<section>
  <div class="container">
    <div class="section-header">
      <h2>Explore Funding Options</h2>
      <p>Current rates, lender comparisons, and eligibility guidance for every major Canadian financing category. Updated July 2026.</p>
    </div>
    <div class="card-grid">
      {fundingOptions.map(o => (
        <a href={o.url} class="card" style="text-decoration: none; color: inherit;">
          <div class="card-icon">{o.icon}</div>
          <h3>{o.name}</h3>
          <p>{o.desc}</p>
          <p style="margin-top: 10px; font-size: 12px; color: var(--gold-dark); font-weight: 600;">{o.cta} →</p>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- How it works -->
<section style="background: var(--surface);">
  <div class="container">
    <div class="section-header"><h2>How It Works</h2></div>
    <div class="steps">
      <div class="step"><div class="step-num">1</div><h3>Tell us your goal</h3><p>What you need funding for, how much, and when. Takes 2 minutes.</p></div>
      <div class="step"><div class="step-num">2</div><h3>Complete the assessment</h3><p>Business profile, revenue, time in business, location. 3–5 minutes total.</p></div>
      <div class="step"><div class="step-num">3</div><h3>Receive potential paths</h3><p>We identify relevant financing categories and flag preparation steps.</p></div>
      <div class="step"><div class="step-num">4</div><h3>Human review</h3><p>A qualified team member reviews before matching you with a financing professional.</p></div>
    </div>
  </div>
</section>

<!-- For professionals -->
<section>
  <div class="container">
    <div class="cta-banner">
      <h2>Financial professional?</h2>
      <p>LeadSniper Marketplace routes consented, human-reviewed business financing opportunities to verified brokers, lenders, and advisors.</p>
      <a href="/for-professionals" class="btn btn-primary btn-lg">Learn About Joining</a>
    </div>
  </div>
</section>

<!-- Disclaimer -->
<section style="padding: 32px 0; background: var(--navy); color: rgba(255,255,255,0.5);">
  <div class="container">
    <p style="font-size: 13px; text-align: center;">
      These are preliminary financing categories for discussion. They are not offers, approvals, commitments, rates, or guarantees.
      Final eligibility and terms are determined by financing providers after complete underwriting.
      LeadSniper Marketplace is a funding assessment platform, not a lender.
    </p>
  </div>
</section>

</FundingLayout>
