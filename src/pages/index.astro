---
const modes = [
  { title: "Exclusive opportunities", text: "One verified professional receives the opportunity after purchase." },
  { title: "Limited shared opportunities", text: "A controlled number of compatible professionals may participate." },
  { title: "Internal opportunities", text: "Strategic cases remain within the assigned advisory team." },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="LeadSniper Marketplace connects qualified business financing opportunities with verified financial professionals." />
    <title>LeadSniper Marketplace</title>
    <style>
      :root { color-scheme: light; font-family: Inter, ui-sans-serif, system-ui, sans-serif; background: #f4f1e8; color: #17231d; }
      body { margin: 0; }
      main { max-width: 1120px; margin: auto; padding: 5rem 1.5rem; }
      .eyebrow { color: #a4462a; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; }
      h1 { max-width: 820px; font-family: Georgia, serif; font-size: clamp(3rem, 8vw, 6.7rem); line-height: .92; font-weight: 500; margin: 1.2rem 0; }
      .lede { max-width: 680px; font-size: 1.3rem; line-height: 1.55; }
      section { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; margin-top: 5rem; background: #8c988f; border: 1px solid #8c988f; }
      article { background: #f4f1e8; padding: 2rem; min-height: 190px; }
      h2 { font-family: Georgia, serif; font-size: 1.7rem; }
      @media (max-width: 760px) { section { grid-template-columns: 1fr; } }
    </style>
  </head>
  <body>
    <main>
      <p class="eyebrow">Business financing opportunity network</p>
      <h1>Qualified demand. Better professional matches.</h1>
      <p class="lede">A consent-led marketplace connecting business owners seeking mortgages, commercial financing, and growth capital with verified financial professionals.</p>
      <section aria-label="Distribution models">
        {modes.map((mode) => <article><h2>{mode.title}</h2><p>{mode.text}</p></article>)}
      </section>
    </main>
  </body>
</html>
